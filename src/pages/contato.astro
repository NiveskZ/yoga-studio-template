---
import Base from '../layouts/Base.astro';
import settings from '../data/settings.json';

const linkWhatsApp = `https://wa.me/${settings.whatsapp.numero}?text=${encodeURIComponent(settings.whatsapp.mensagem)}`;

// Extrai o @usuario do link do Instagram (última parte do endereço)
const instagramHandle = '@' + new URL(settings.instagram).pathname.replaceAll('/', '');

// Links de mapa gerados a partir do endereço do painel
const enderecoCodificado = encodeURIComponent(settings.endereco);
const linkRota = `https://www.google.com/maps/search/?api=1&query=${enderecoCodificado}`;
const mapaEmbed = `https://www.google.com/maps?q=${enderecoCodificado}&output=embed`;

// Ícones (desenhos SVG, sem imagens externas) usados na linha de canais.
// Cada valor é o "miolo" de um <svg> 24x24 desenhado com traços.
const icones = {
  email: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/>',
  instagram: '<rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.3" cy="6.7" r="1" fill="currentColor" stroke="none"/>',
  agenda: '<rect x="3" y="5" width="18" height="16" rx="2"/><path d="M8 3v4M16 3v4M3 11h18"/>',
  whatsapp: '<path d="M21 11.5a8.5 8.5 0 0 1-12.4 7.5L3 21l2-5.6A8.5 8.5 0 1 1 21 11.5Z"/>',
  telefone: '<path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.2 2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7 12.8 12.8 0 0 0 .7 2.8 2 2 0 0 1-.4 2.1L8.1 9.9a16 16 0 0 0 6 6l1.3-1.3a2 2 0 0 1 2.1-.4 12.8 12.8 0 0 0 2.8.7 2 2 0 0 1 1.7 2Z"/>',
  link: '<path d="M10 13a5 5 0 0 0 7.5.5l3-3a5 5 0 0 0-7-7l-1.7 1.7"/><path d="M14 11a5 5 0 0 0-7.5-.5l-3 3a5 5 0 0 0 7 7l1.7-1.7"/>',
};

// Escolhe o ícone de um contato adicional olhando o link e o título
function tipoDoContato(contato: { rotulo?: string; link?: string }): keyof typeof icones {
  const pista = `${contato.link ?? ''} ${contato.rotulo ?? ''}`.toLowerCase();
  if (pista.includes('whatsapp') || pista.includes('wa.me')) return 'whatsapp';
  if (pista.includes('instagram')) return 'instagram';
  if (pista.includes('mail')) return 'email';
  if (contato.link) return 'link';
  return 'telefone';
}
---

<Base titulo="Contato" descricao={`Entre em contato com o ${settings.nome}.`}>
  <section class="secao">
    <div class="container contato">
      <h1 class="secao__titulo">Fale com a gente</h1>
      <p class="contato__intro">
        Quer agendar uma aula experimental, tirar dúvidas sobre horários ou
        saber mais sobre as vivências? O jeito mais rápido é pelo WhatsApp.
      </p>

      <a href={linkWhatsApp} class="botao botao--whatsapp" target="_blank" rel="noopener">
        Chamar no WhatsApp
      </a>

      <!-- Outros canais: linha discreta de ícone + texto.
           O endereço não se repete aqui porque já aparece em "Como chegar". -->
      <ul class="canais">
        {settings.tecnofit && (
          <li>
            <a href={settings.tecnofit} target="_blank" rel="noopener">
              <svg class="canais__icone" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icones.agenda} />
              Agendar pelo app
            </a>
          </li>
        )}
        <li>
          <a href={`mailto:${settings.email}`}>
            <svg class="canais__icone" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icones.email} />
            {settings.email}
          </a>
        </li>
        <li>
          <a href={settings.instagram} target="_blank" rel="noopener">
            <svg class="canais__icone" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icones.instagram} />
            {instagramHandle}
          </a>
        </li>

        <!-- Contatos adicionais cadastrados no painel (lista vazia = nada aparece) -->
        {(settings.contatos_extras ?? []).map((contato) => (
          <li>
            {contato.link ? (
              <a href={contato.link} target="_blank" rel="noopener" title={contato.valor}>
                <svg class="canais__icone" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icones[tipoDoContato(contato)]} />
                {contato.rotulo}
              </a>
            ) : (
              <span>
                <svg class="canais__icone" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icones[tipoDoContato(contato)]} />
                {contato.rotulo}: {contato.valor}
              </span>
            )}
          </li>
        ))}
      </ul>

      <!-- ===== Como chegar ===== -->
      <div class="como-chegar" id="como-chegar">
        <h2>Como chegar</h2>
        <p class="como-chegar__endereco">{settings.endereco}</p>

        <!-- O mapa do Google só carrega quando a pessoa abre (privacidade:
             o site continua sem rastreadores até o visitante pedir o mapa) -->
        <details class="mapa">
          <summary>Ver mapa</summary>
          <iframe
            src={mapaEmbed}
            width="100%"
            height="340"
            style="border:0"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title={`Mapa: ${settings.endereco}`}
          ></iframe>
        </details>

        <a href={linkRota} class="botao" target="_blank" rel="noopener">
          Traçar rota no Google Maps
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  .contato {
    text-align: center;
  }

  .contato__intro {
    max-width: 560px;
    margin: 0 auto 2rem;
    color: var(--cor-texto-suave);
  }

  .canais {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.9rem 2.5rem;
    margin: 2.75rem 0 0;
    padding: 0;
  }

  .canais a,
  .canais span {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--cor-texto-suave);
    text-decoration: none;
    font-size: 0.98rem;
  }

  .canais a:hover {
    color: var(--cor-primaria);
  }

  .canais__icone {
    width: 19px;
    height: 19px;
    color: var(--cor-primaria);
    flex-shrink: 0;
  }

  .como-chegar {
    margin-top: 3.5rem;
  }

  .como-chegar__endereco {
    color: var(--cor-texto-suave);
    margin: 0.5rem 0 1.25rem;
  }

  .mapa {
    max-width: 720px;
    margin: 0 auto 1.5rem;
  }

  .mapa summary {
    cursor: pointer;
    font-weight: 700;
    color: var(--cor-primaria);
    padding: 0.6rem;
    list-style: none;
  }

  .mapa summary::-webkit-details-marker {
    display: none;
  }

  .mapa summary::before {
    content: '▸ ';
  }

  .mapa[open] summary::before {
    content: '▾ ';
  }

  .mapa iframe {
    border-radius: var(--raio);
    box-shadow: var(--sombra);
  }
</style>
