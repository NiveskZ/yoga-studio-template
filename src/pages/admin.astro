---
// Painel de edição (Decap CMS). É uma rota Astro (e não um arquivo em
// public/) para que /admin funcione igual no dev server e em produção.
// A configuração do painel continua em public/admin/config.yml.
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>Painel do site</title>
    <!-- Diz ao Decap onde está o config.yml (senão ele procuraria relativo à URL) -->
    <link href="/admin/config.yml" type="text/yaml" rel="cms-config-url" />
  </head>
  <body>
    <!-- Versão fixada: evita atualizações surpresa e melhora o cache.
         Para atualizar: trocar o número aqui (ver github.com/decaporg/decap-cms/releases) -->
    <script is:inline src="https://unpkg.com/decap-cms@3.14.1/dist/decap-cms.js"></script>

    <!-- Cores por nível nas listas do EDITOR (lado esquerdo), para não se
         perder em lista dentro de lista (ex: dias > aulas). Usa seletores
         por "contém no nome da classe" porque o Decap gera nomes com hash. -->
    <style is:global>
      /* Cada campo do editor vive num "ControlContainer"; itens de lista têm
         uma barra "StyledListItemTopBar". Contando os containers aninhados,
         sabemos a profundidade e pintamos cada nível de uma cor. */

      /* Nível 1 (ex: cada DIA da semana): faixa teal */
      [class*='ControlContainer'] [class*='ListItemTopBar'] {
        background: #dfe8e0;
        border-left: 4px solid #6b7f6e;
      }

      /* Nível 2 (ex: cada AULA dentro do dia): faixa areia */
      [class*='ControlContainer'] [class*='ControlContainer'] [class*='ListItemTopBar'] {
        background: #f1ead2;
        border-left: 4px solid #b8963f;
      }

      /* Nível 3 (ex: cada PLANO dentro do grupo): faixa lilás */
      [class*='ControlContainer'] [class*='ControlContainer'] [class*='ControlContainer'] [class*='ListItemTopBar'] {
        background: #ead9e4;
        border-left: 4px solid #96537c;
      }

      /* ===== Aparência geral do painel (discreta, nas cores da marca) ===== */

      /* Visão em blocos: cartões com altura natural e grade alinhada
         (por padrão eles ficam enormes, vazios e vazando do container) */
      /* O container é o mesmo nas duas visões; o :has() garante que a grade
         só é aplicada quando os cartões são do modo blocos (GridCard) */
      ul[class*='CardsGrid']:has(> li[class*='GridCard']) {
        display: grid !important;
        grid-template-columns: repeat(2, 1fr);
        gap: 14px;
        /* mesma largura do cartão de título da coleção, para alinhar com ele */
        width: 100% !important;
        max-width: 682px;
        margin: 16px 0 !important;
        padding: 0 !important;
      }

      ul[class*='CardsGrid'] > li[class*='GridCard'] {
        width: 100% !important;
        height: auto !important;
        min-height: 0 !important;
        margin: 0 !important;
        border: 1px solid #e4e2d8;
        border-radius: 10px;
        box-shadow: 0 1px 5px rgba(47, 62, 64, 0.06);
      }

      ul[class*='CardsGrid'] > li[class*='GridCard'] a {
        display: block;
        padding: 14px 16px;
        font-weight: 600;
        color: #4e5f51;
      }

      ul[class*='CardsGrid'] > li[class*='GridCard'] h2 {
        margin: 0;
        font-size: 16px;
      }

      /* Botões de ação principais na cor da marca */
      a[class*='CollectionTopNewButton'],
      button[class*='CollectionTopNewButton'] {
        background-color: #6b7f6e !important;
      }

      a[class*='CollectionTopNewButton']:hover,
      button[class*='CollectionTopNewButton']:hover {
        background-color: #4e5f51 !important;
      }

      /* Menu lateral: hover na cor da marca */
      a[class*='SidebarNavLink']:hover {
        color: #6b7f6e !important;
      }

      /* Título da coleção com a serifa do site */
      h1[class*='CollectionTopHeading'] {
        font-family: Georgia, 'Times New Roman', serif;
        color: #4e5f51;
      }
    </style>

    <script is:inline>
      // Previews do editor com a "cara" do site, para cada tipo de conteúdo.
      if (window.CMS) {
        var CMS = window.CMS;
        CMS.registerPreviewStyle('/admin/preview.css');

        var h = window.h;
        var createClass = window.createClass;

        if (h && createClass) {
          var ORDEM_DIAS = [
            'Segunda-feira', 'Terça-feira', 'Quarta-feira',
            'Quinta-feira', 'Sexta-feira', 'Sábado', 'Domingo',
          ];

          // Título de seção com filete, como no site
          function tituloSecao(texto) {
            return h('h1', { className: 'pv-titulo-secao' }, texto);
          }

          // ----- Horários: os mesmos cartões da página /horarios -----
          var HorariosPreview = createClass({
            render: function () {
              var data = this.props.entry.get('data');
              var dias = (data && data.toJS().dias) || [];
              dias = dias
                .filter(function (d) { return d && d.aulas && d.aulas.length; })
                .sort(function (a, b) { return ORDEM_DIAS.indexOf(a.dia) - ORDEM_DIAS.indexOf(b.dia); });

              return h('div', { className: 'pv-pagina' },
                tituloSecao('Horários das aulas'),
                h('div', { className: 'pv-grade' },
                  dias.map(function (d, i) {
                    var aulas = d.aulas.slice().sort(function (a, b) {
                      return String(a.hora).localeCompare(String(b.hora));
                    });
                    return h('div', { className: 'pv-cartao', key: i },
                      h('h3', {}, d.dia),
                      h('ul', {},
                        aulas.map(function (a, j) {
                          return h('li', { key: j },
                            h('span', { className: 'pv-hora' }, a.hora),
                            h('div', {},
                              h('strong', {}, a.aula),
                              h('p', { className: 'pv-detalhe' },
                                [a.professora, a.observacao].filter(Boolean).join(' · '))
                            )
                          );
                        })
                      )
                    );
                  })
                )
              );
            },
          });
          CMS.registerPreviewTemplate('horarios', HorariosPreview);

          // ----- Notícia: como a página da notícia no site -----
          var NoticiaPreview = createClass({
            render: function () {
              var data = this.props.entry.get('data');
              var titulo = data ? data.get('titulo') : '';
              var dataPub = data ? data.get('data') : '';
              return h('article', { className: 'pv-pagina pv-artigo' },
                h('p', { className: 'pv-data' }, String(dataPub || '')),
                h('h1', {}, titulo),
                h('div', { className: 'pv-corpo' }, this.props.widgetFor('body'))
              );
            },
          });
          CMS.registerPreviewTemplate('noticias', NoticiaPreview);

          // ----- Configurações gerais: banner (home) + canais da página Contato -----
          // Ícones iguais aos do site (src/pages/contato.astro)
          var ICONES_CANAL = {
            email: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/>',
            instagram: '<rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.3" cy="6.7" r="1" fill="currentColor" stroke="none"/>',
            agenda: '<rect x="3" y="5" width="18" height="16" rx="2"/><path d="M8 3v4M16 3v4M3 11h18"/>',
            whatsapp: '<path d="M21 11.5a8.5 8.5 0 0 1-12.4 7.5L3 21l2-5.6A8.5 8.5 0 1 1 21 11.5Z"/>',
            telefone: '<path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.2 2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7 12.8 12.8 0 0 0 .7 2.8 2 2 0 0 1-.4 2.1L8.1 9.9a16 16 0 0 0 6 6l1.3-1.3a2 2 0 0 1 2.1-.4 12.8 12.8 0 0 0 2.8.7 2 2 0 0 1 1.7 2Z"/>',
            link: '<path d="M10 13a5 5 0 0 0 7.5.5l3-3a5 5 0 0 0-7-7l-1.7 1.7"/><path d="M14 11a5 5 0 0 0-7.5-.5l-3 3a5 5 0 0 0 7 7l1.7-1.7"/>',
          };
          function canal(icone, texto) {
            var svg = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">' + ICONES_CANAL[icone] + '</svg>';
            return h('li', { className: 'pv-canal' },
              h('span', { className: 'pv-canal__icone', dangerouslySetInnerHTML: { __html: svg } }),
              texto
            );
          }
          // Extrai o @usuario do link do Instagram, como o site faz
          function handleInstagram(url) {
            try { return '@' + new URL(url).pathname.replaceAll('/', ''); } catch (e) { return url || ''; }
          }
          // Mesma regra do site para escolher o ícone de um contato adicional
          function tipoDoContato(c) {
            var pista = (((c && c.link) || '') + ' ' + ((c && c.rotulo) || '')).toLowerCase();
            if (pista.indexOf('whatsapp') >= 0 || pista.indexOf('wa.me') >= 0) return 'whatsapp';
            if (pista.indexOf('instagram') >= 0) return 'instagram';
            if (pista.indexOf('mail') >= 0) return 'email';
            if (c && c.link) return 'link';
            return 'telefone';
          }
          var SettingsPreview = createClass({
            render: function () {
              var d = this.props.entry.get('data').toJS();
              var banner = d.banner || {};
              var extras = d.contatos_extras || [];
              return h('div', { className: 'pv-pagina' },
                h('p', { className: 'pv-onde' }, 'Página inicial (banner):'),
                h('div', { className: 'pv-hero' },
                  h('p', { className: 'pv-slogan' }, d.slogan || ''),
                  h('h1', {}, banner.titulo || ''),
                  h('p', { className: 'pv-subtitulo' }, banner.subtitulo || ''),
                  h('span', { className: 'pv-botao' }, banner.botao_texto || '')
                ),
                h('p', { className: 'pv-onde' }, 'Página Contato (abaixo do botão de WhatsApp):'),
                h('ul', { className: 'pv-canais' },
                  d.tecnofit ? canal('agenda', 'Agendar pelo app') : null,
                  canal('email', d.email || ''),
                  canal('instagram', handleInstagram(d.instagram)),
                  extras.map(function (c, i) {
                    var texto = c && c.link ? (c.rotulo || '') : ((c && c.rotulo) || '') + ': ' + ((c && c.valor) || '');
                    return h('li', { className: 'pv-canal', key: i },
                      h('span', { className: 'pv-canal__icone', dangerouslySetInnerHTML: { __html: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">' + ICONES_CANAL[tipoDoContato(c)] + '</svg>' } }),
                      texto
                    );
                  })
                ),
                h('p', { className: 'pv-detalhe pv-centro' }, 'WhatsApp do botão: ' + ((d.whatsapp && d.whatsapp.numero) || '') + '  ·  Endereço (seção "Como chegar"): ' + (d.endereco || ''))
              );
            },
          });
          CMS.registerPreviewTemplate('settings', SettingsPreview);

          // ----- Planos: grupos com os balõezinhos, como no site -----
          var PlanosPreview = createClass({
            render: function () {
              var getAsset = this.props.getAsset;
              var d = this.props.entry.get('data').toJS();
              var grupos = d.grupos || [];
              var parcerias = d.parcerias || [];
              return h('div', { className: 'pv-pagina' },
                tituloSecao('Planos e valores'),
                h('p', { className: 'pv-experimental' }, d.aula_experimental || ''),
                grupos.map(function (g, i) {
                  return h('div', { key: i },
                    h('h3', { className: 'pv-grupo-nome' }, (g.nome || '') + (g.aberto ? '  (aberto por padrão)' : '')),
                    h('div', { className: 'pv-grade' },
                      (g.planos || []).map(function (p, j) {
                        return h('div', { className: 'pv-cartao pv-plano' + (p.destaque ? ' pv-plano--destaque' : ''), key: j },
                          p.destaque ? h('span', { className: 'pv-selo' }, 'Mais escolhido') : null,
                          h('strong', {}, p.nome || ''),
                          h('p', { className: 'pv-preco' }, p.preco || ''),
                          p.descricao ? h('p', { className: 'pv-detalhe' }, p.descricao) : null
                        );
                      })
                    )
                  );
                }),
                h('p', { className: 'pv-detalhe pv-centro' }, d.observacao || ''),
                h('p', { className: 'pv-centro' },
                  parcerias.map(function (p, i) {
                    var nome = (p && p.nome) ? p.nome : String(p || '');
                    var logo = p && p.logo;
                    var complemento = (p && p.complemento) ? ' (' + p.complemento + ')' : '';
                    return h('span', { className: 'pv-chip', key: i },
                      logo
                        ? h('img', { className: 'pv-chip-logo', src: String(getAsset(logo)), alt: nome })
                        : '✓ ' + nome,
                      complemento
                    );
                  })
                )
              );
            },
          });
          CMS.registerPreviewTemplate('planos', PlanosPreview);

          // ----- Galeria: grade de fotos, como no site -----
          var GaleriaPreview = createClass({
            render: function () {
              var getAsset = this.props.getAsset;
              var d = this.props.entry.get('data').toJS();
              var fotos = d.fotos || [];
              return h('div', { className: 'pv-pagina' },
                tituloSecao('Galeria'),
                h('div', { className: 'pv-fotos' },
                  fotos.map(function (f, i) {
                    return h('figure', { key: i },
                      f.imagem ? h('img', { src: String(getAsset(f.imagem)) }) : null,
                      f.legenda ? h('figcaption', {}, f.legenda) : null
                    );
                  })
                )
              );
            },
          });
          CMS.registerPreviewTemplate('galeria', GaleriaPreview);

          // ----- Professora: cartão como na página /professoras -----
          var ProfessoraPreview = createClass({
            render: function () {
              var getAsset = this.props.getAsset;
              var data = this.props.entry.get('data');
              var foto = data.get('foto');
              return h('div', { className: 'pv-pagina' },
                h('div', { className: 'pv-cartao pv-professora' },
                  foto ? h('img', { className: 'pv-foto-redonda', src: String(getAsset(foto)) }) : null,
                  h('h2', {}, data.get('nome') || ''),
                  h('p', { className: 'pv-especialidade' }, data.get('especialidade') || ''),
                  h('div', { className: 'pv-detalhe' }, this.props.widgetFor('body'))
                )
              );
            },
          });
          CMS.registerPreviewTemplate('professoras', ProfessoraPreview);

          // ----- Modalidade: como o cartão da página /modalidades -----
          var ModalidadePreview = createClass({
            render: function () {
              var data = this.props.entry.get('data');
              return h('div', { className: 'pv-pagina' },
                h('div', { className: 'pv-cartao' },
                  h('h2', {}, data.get('nome') || ''),
                  h('p', {},
                    data.get('ritmo') ? h('span', { className: 'pv-chip' }, data.get('ritmo')) : null,
                    ' ',
                    data.get('professora') ? h('span', { className: 'pv-chip pv-chip--suave' }, 'com ' + data.get('professora')) : null
                  ),
                  h('p', { className: 'pv-detalhe' }, data.get('resumo') || ''),
                  h('div', { className: 'pv-corpo' }, this.props.widgetFor('body'))
                )
              );
            },
          });
          CMS.registerPreviewTemplate('modalidades', ModalidadePreview);
        }
      }
    </script>
  </body>
</html>
