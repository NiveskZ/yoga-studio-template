---
// Galeria de fotos gerenciada pelo /admin (src/data/galeria.json).
// Futuramente (SPEC-005) esta página também mostrará as publicações do
// Instagram buscadas no build; a galeria manual continua como fallback.
import Base from '../layouts/Base.astro';
import settings from '../data/settings.json';
import galeriaData from '../data/galeria.json';
---

<Base titulo="Galeria" descricao="Momentos das aulas e vivências do estúdio.">
  <section class="secao">
    <div class="container">
      <h1 class="secao__titulo">Galeria</h1>
      <p class="intro">Momentos das nossas aulas, vivências e encontros.</p>

      <div class="grade">
        {galeriaData.fotos.map((foto) => (
          <figure class="foto">
            <img src={foto.imagem} alt={foto.legenda ?? 'Foto do estúdio'} loading="lazy" />
            {foto.legenda && <figcaption>{foto.legenda}</figcaption>}
          </figure>
        ))}
      </div>

      <div class="instagram-cta">
        <p>Acompanhe o dia a dia do estúdio no Instagram:</p>
        <a href={settings.instagram} class="botao" target="_blank" rel="noopener">
          Seguir no Instagram
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  .intro {
    text-align: center;
    max-width: 620px;
    margin: -1rem auto 2.5rem;
    color: var(--cor-texto-suave);
  }

  .grade {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem;
  }

  .foto {
    margin: 0;
  }

  .foto img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--raio);
    box-shadow: var(--sombra);
  }

  .foto figcaption {
    font-size: 0.85rem;
    color: var(--cor-texto-suave);
    margin-top: 0.4rem;
    text-align: center;
  }

  .instagram-cta {
    text-align: center;
    margin-top: 3rem;
  }

  .instagram-cta p {
    margin-bottom: 1rem;
    color: var(--cor-texto-suave);
  }
</style>
