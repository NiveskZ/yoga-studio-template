---
import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';
import settings from '../data/settings.json';
import planosData from '../data/planos.json';

const linkWhatsApp = `https://wa.me/${settings.whatsapp.numero}?text=${encodeURIComponent(settings.whatsapp.mensagem)}`;

const modalidades = (await getCollection('modalidades'))
  .sort((a, b) => a.data.ordem - b.data.ordem);

const modalidadesComTexto = await Promise.all(
  modalidades.map(async (m) => {
    const { Content } = await render(m);
    return { ...m, Content };
  })
);
---

<Base titulo="Modalidades" descricao="Conheça as modalidades do estúdio: Hatha Flow, Vinyasa e Yin Yoga, e as diferenças entre elas.">
  <section class="secao">
    <div class="container">
      <h1 class="secao__titulo">Modalidades</h1>
      <p class="intro">
        Qual prática combina mais com você? Cada estilo de yoga tem um ritmo e
        um propósito. Conheça as modalidades do estúdio e, na dúvida, experimente todas.
      </p>

      <div class="modalidades">
        {modalidadesComTexto.map(({ data, Content }) => (
          <article class="cartao modalidade">
            <header class="modalidade__cabecalho">
              <h2>{data.nome}</h2>
              <div class="modalidade__tags">
                {data.ritmo && <span class="tag">{data.ritmo}</span>}
                {data.professora && <span class="tag tag--suave">com {data.professora}</span>}
              </div>
            </header>
            <div class="modalidade__texto">
              <Content />
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== Planos e valores ===== -->
  <!-- O id="planos" permite linkar direto: /modalidades#planos -->
  <section class="secao secao--suave" id="planos">
    <div class="container">
      <h2 class="secao__titulo">Planos e valores</h2>

      <p class="planos__experimental">{planosData.aula_experimental}</p>

      <div class="planos">
        {planosData.grupos.map((grupo) => (
          <details class="grupo" open={grupo.aberto}>
            <summary>{grupo.nome}</summary>
            <div class="grupo__planos">
              {grupo.planos.map((plano) => (
                <div class:list={['cartao', 'plano', { 'plano--destaque': plano.destaque }]}>
                  {plano.destaque && <span class="plano__selo">Mais escolhido</span>}
                  <h3>{plano.nome}</h3>
                  <p class="plano__preco">{plano.preco}</p>
                  {plano.descricao && <p class="plano__descricao">{plano.descricao}</p>}
                </div>
              ))}
            </div>
          </details>
        ))}
      </div>

      <p class="planos__observacao">{planosData.observacao}</p>
      <div class="planos__parcerias">
        <span class="planos__parcerias-rotulo">Aceitamos:</span>
        {planosData.parcerias.map((parceria) => (
          <span class="chip">
            <svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
              <path d="M2.5 8.5 L6 12 L13.5 4" />
            </svg>
            {parceria}
          </span>
        ))}
      </div>

      <div class="planos__cta">
        <a href={linkWhatsApp} class="botao botao--whatsapp" target="_blank" rel="noopener">
          Agendar aula experimental
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  .intro {
    text-align: center;
    max-width: 620px;
    margin: -1rem auto 2.5rem;
    color: var(--cor-texto-suave);
  }

  .modalidades {
    display: grid;
    gap: 1.5rem;
    max-width: 760px;
    margin: 0 auto;
  }

  .modalidade__cabecalho {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .modalidade__tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    background: var(--cor-primaria);
    color: var(--cor-branco);
    font-size: 0.78rem;
    font-weight: 700;
    padding: 0.2rem 0.75rem;
    border-radius: 999px;
  }

  .tag--suave {
    background: var(--cor-fundo-suave);
    color: var(--cor-texto);
  }

  .modalidade__texto :global(p) {
    margin-bottom: 0.9rem;
    color: var(--cor-texto-suave);
  }

  .planos__experimental {
    text-align: center;
    font-weight: 700;
    color: var(--cor-primaria-escura);
    margin: -1rem 0 2rem;
  }

  .planos {
    display: grid;
    gap: 1rem;
    max-width: 860px;
    margin: 0 auto;
  }

  /* O <summary> é o "botão" que abre e fecha o grupo */
  .grupo summary {
    cursor: pointer;
    font-family: var(--fonte-titulo);
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--cor-primaria-escura);
    background: var(--cor-branco);
    border-radius: var(--raio);
    box-shadow: var(--sombra);
    padding: 1rem 1.75rem;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: border-radius 0.15s ease;
  }

  .grupo summary::-webkit-details-marker {
    display: none;
  }

  /* Setinha que gira quando o grupo está aberto */
  .grupo summary::after {
    content: '▾';
    color: var(--cor-primaria);
    transition: transform 0.2s ease;
  }

  .grupo[open] summary::after {
    transform: rotate(180deg);
  }

  /* Os "balõezinhos" de plano dentro do grupo aberto */
  .grupo__planos {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.25rem;
    padding: 1.5rem 0.25rem 0.75rem;
  }

  .plano {
    text-align: center;
    position: relative;
  }

  .plano--destaque {
    outline: 2px solid var(--cor-primaria);
  }

  .plano__selo {
    position: absolute;
    top: -0.8rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--cor-primaria);
    color: var(--cor-branco);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.15rem 0.9rem;
    border-radius: 999px;
    white-space: nowrap;
  }

  .plano h3 {
    font-size: 1.15rem;
  }

  .plano__preco {
    font-family: var(--fonte-titulo);
    font-size: 1.7rem;
    font-weight: 700;
    color: var(--cor-primaria-escura);
    margin: 0.3rem 0 0.2rem;
  }

  .plano__descricao {
    font-size: 0.88rem;
    color: var(--cor-texto-suave);
  }

  .planos__observacao {
    text-align: center;
    font-size: 0.9rem;
    color: var(--cor-texto-suave);
    margin-top: 1.75rem;
  }

  /* Selos de parcerias (Wellhub, Gympass...) */
  .planos__parcerias {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  .planos__parcerias-rotulo {
    font-weight: 700;
    color: var(--cor-texto-suave);
    font-size: 0.9rem;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--cor-branco);
    border: 1px solid rgba(107, 127, 110, 0.35);
    color: var(--cor-primaria-escura);
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.3rem 0.9rem;
    border-radius: 999px;
    box-shadow: var(--sombra);
  }

  .chip svg {
    color: var(--cor-primaria);
  }

  .planos__cta {
    text-align: center;
    margin-top: 1.5rem;
  }
</style>
