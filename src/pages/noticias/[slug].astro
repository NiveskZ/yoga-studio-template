---
// Página de uma notícia individual. O [slug] no nome do arquivo significa
// que o Astro gera uma página para cada notícia (uma por arquivo .md).
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const noticias = await getCollection('noticias');
  return noticias.map((noticia) => ({
    params: { slug: noticia.id },
    props: { noticia },
  }));
}

const { noticia } = Astro.props;
const { Content } = await render(noticia);
---

<Base titulo={noticia.data.titulo} descricao={noticia.data.resumo}>
  <article class="secao">
    <div class="container conteudo">
      <a href="/noticias" class="voltar">← Todas as notícias</a>
      <time>
        {noticia.data.data.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}
      </time>
      <h1>{noticia.data.titulo}</h1>
      {noticia.data.imagem && <img src={noticia.data.imagem} alt="" class="imagem" />}
      <div class="corpo">
        <Content />
      </div>
    </div>
  </article>
</Base>

<style>
  .conteudo {
    max-width: 680px;
  }

  .voltar {
    display: inline-block;
    text-decoration: none;
    font-weight: 700;
    margin-bottom: 2rem;
  }

  time {
    color: var(--cor-texto-suave);
    font-size: 0.9rem;
  }

  h1 {
    margin: 0.5rem 0 1.5rem;
  }

  .imagem {
    border-radius: var(--raio);
    margin-bottom: 1.5rem;
  }

  /* :global aplica o estilo ao HTML vindo do markdown */
  .corpo :global(p) {
    margin-bottom: 1.1rem;
  }
</style>
