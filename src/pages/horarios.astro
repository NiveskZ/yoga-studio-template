---
import Base from '../layouts/Base.astro';
import TabelaHorarios from '../components/TabelaHorarios.astro';
import settings from '../data/settings.json';

const linkWhatsApp = `https://wa.me/${settings.whatsapp.numero}?text=${encodeURIComponent(settings.whatsapp.mensagem)}`;
---

<Base titulo="Horários" descricao="Horários das aulas de yoga do estúdio.">
  <section class="secao">
    <div class="container">
      <h1 class="secao__titulo">Horários das aulas</h1>
      <TabelaHorarios />
      <div class="aviso">
        <p>Quer garantir sua vaga ou tirar dúvidas sobre alguma aula?</p>
        <p class="aviso__botoes">
          <!-- O botão de agendamento só aparece se o link estiver preenchido
               no painel (Configurações do site > Link de agendamento) -->
          {settings.tecnofit && (
            <a href={settings.tecnofit} class="botao" target="_blank" rel="noopener">Agendar aula (app)</a>
          )}
          <a href={linkWhatsApp} class="botao botao--whatsapp" target="_blank" rel="noopener">Chamar no WhatsApp</a>
        </p>
      </div>
    </div>
  </section>
</Base>

<style>
  .aviso {
    text-align: center;
    margin-top: 2.5rem;
    color: var(--cor-texto-suave);
  }

  .aviso__botoes {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 1.25rem;
  }
</style>
