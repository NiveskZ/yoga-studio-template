---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import TabelaHorarios from '../components/TabelaHorarios.astro';
import settings from '../data/settings.json';

const linkWhatsApp = `https://wa.me/${settings.whatsapp.numero}?text=${encodeURIComponent(settings.whatsapp.mensagem)}`;

// Pega as 3 notícias mais recentes para mostrar na home
const noticias = (await getCollection('noticias'))
  .sort((a, b) => b.data.data.getTime() - a.data.data.getTime())
  .slice(0, 3);

const modalidades = (await getCollection('modalidades'))
  .sort((a, b) => a.data.ordem - b.data.ordem);
---

<Base titulo="Início">
  <!-- ===== Banner principal (hero) ===== -->
  <section class="hero">
    <!-- Decoração: bolhas que "respiram" e lótus ao fundo (só CSS, sem JS) -->
    <div class="hero__blob hero__blob--1" aria-hidden="true"></div>
    <div class="hero__blob hero__blob--2" aria-hidden="true"></div>
    <svg class="hero__lotus-fundo" viewBox="0 0 48 32" fill="none" stroke="currentColor" stroke-width="0.8" stroke-linecap="round" aria-hidden="true">
      <path d="M24 28 C20 20, 20 10, 24 4 C28 10, 28 20, 24 28 Z" />
      <path d="M24 28 C16 26, 9 20, 8 12 C16 14, 22 20, 24 28 Z" />
      <path d="M24 28 C32 26, 39 20, 40 12 C32 14, 26 20, 24 28 Z" />
    </svg>

    <div class="container hero__conteudo">
      <svg class="hero__logo" viewBox="0 0 48 48" width="120" height="120" role="img" aria-label={`Logo do ${settings.nome}`}>
        <circle cx="24" cy="24" r="23" fill="var(--cor-primaria)" />
        <g stroke="var(--cor-fundo)" stroke-width="2" fill="none" stroke-linecap="round">
          <path d="M24 36 C20 29, 20 18, 24 11 C28 18, 28 29, 24 36 Z" />
          <path d="M24 36 C17 34, 10 28, 9 20 C17 22, 22 28, 24 36 Z" />
          <path d="M24 36 C31 34, 38 28, 39 20 C31 22, 26 28, 24 36 Z" />
        </g>
      </svg>
      <p class="hero__slogan">{settings.slogan}</p>
      <h1>{settings.banner.titulo}</h1>
      <p class="hero__subtitulo">{settings.banner.subtitulo}</p>
      <a href={linkWhatsApp} class="botao botao--whatsapp" target="_blank" rel="noopener">
        {settings.banner.botao_texto}
      </a>
    </div>

    <!-- Onda orgânica na transição do banner para o conteúdo -->
    <svg class="hero__onda" viewBox="0 0 1440 70" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0,42 C240,72 480,4 720,26 C960,48 1200,12 1440,42 L1440,70 L0,70 Z" fill="var(--cor-fundo)" />
    </svg>
  </section>

  <!-- ===== Sobre (resumo) ===== -->
  <section class="secao">
    <div class="container sobre-resumo">
      <h2 class="secao__titulo">Um espaço para fluir</h2>
      <p>{settings.sobre_resumo}</p>
      <a href="/sobre" class="sobre-resumo__link">Conheça nossa história →</a>
    </div>
  </section>

  <!-- ===== Modalidades ===== -->
  <section class="secao secao--suave">
    <div class="container">
      <h2 class="secao__titulo">Modalidades</h2>
      <div class="modalidades-grade">
        {modalidades.map((m) => (
          <a href="/modalidades" class="cartao modalidade-cartao">
            <h3>{m.data.nome}</h3>
            {m.data.ritmo && <span class="modalidade-cartao__ritmo">{m.data.ritmo}</span>}
            <p>{m.data.resumo}</p>
          </a>
        ))}
      </div>
      <p class="modalidades-link">
        <a href="/modalidades">Ver detalhes, planos e valores →</a>
      </p>
    </div>
  </section>

  <!-- ===== Horários ===== -->
  <section class="secao">
    <div class="container">
      <h2 class="secao__titulo">Horários das aulas</h2>
      <TabelaHorarios />
    </div>
  </section>

  <!-- ===== Últimas notícias ===== -->
  {noticias.length > 0 && (
    <section class="secao secao--suave">
      <div class="container">
        <h2 class="secao__titulo">Novidades</h2>
        <div class="noticias-grade">
          {noticias.map((noticia) => (
            <a href={`/noticias/${noticia.id}`} class="cartao noticia-cartao">
              <time class="noticia-cartao__data">
                {noticia.data.data.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}
              </time>
              <h3>{noticia.data.titulo}</h3>
              {noticia.data.resumo && <p>{noticia.data.resumo}</p>}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ===== Chamada final ===== -->
  <section class="secao">
    <div class="container cta-final">
      <h2>Pronta(o) para começar?</h2>
      <p>Venha fazer uma aula experimental e sentir na prática.</p>
      <a href={linkWhatsApp} class="botao botao--whatsapp" target="_blank" rel="noopener">
        Falar no WhatsApp
      </a>
    </div>
  </section>
</Base>

<style>
  .hero {
    /* Gradiente suave nos tons da logo, até termos as fotos do estúdio.
       Para usar uma foto: background: url('/images/banner.jpg') center/cover; */
    background: linear-gradient(160deg, #e6f0ef 0%, #cfe5e5 55%, #a9d3d6 100%);
    padding: 5rem 0 7.5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero__conteudo {
    position: relative; /* fica acima da decoração */
  }

  .hero__logo {
    border-radius: 50%;
    box-shadow: var(--sombra);
    margin: 0 auto 1.5rem;
  }

  /* Bolhas suaves que "respiram" no ritmo de uma respiração lenta */
  .hero__blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(40px);
    animation: respirar 9s ease-in-out infinite alternate;
  }

  .hero__blob--1 {
    width: 380px;
    height: 380px;
    top: -120px;
    left: -100px;
    background: rgba(251, 250, 243, 0.55);
  }

  .hero__blob--2 {
    width: 460px;
    height: 460px;
    bottom: -180px;
    right: -120px;
    background: rgba(126, 198, 203, 0.35);
    animation-delay: -4.5s;
  }

  /* Lótus grande e sutil ao fundo, à direita */
  .hero__lotus-fundo {
    position: absolute;
    width: 560px;
    right: -110px;
    bottom: -40px;
    color: var(--cor-primaria);
    opacity: 0.1;
  }

  @keyframes respirar {
    from { transform: scale(1) translateY(0); }
    to { transform: scale(1.12) translateY(-14px); }
  }

  /* Respeita quem prefere menos movimento (acessibilidade) */
  @media (prefers-reduced-motion: reduce) {
    .hero__blob { animation: none; }
  }

  .hero__onda {
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    height: 60px;
  }

  @media (max-width: 700px) {
    .hero__lotus-fundo { width: 340px; right: -90px; }
  }

  .hero__slogan {
    text-transform: uppercase;
    letter-spacing: 0.25em;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--cor-primaria-escura);
    margin-bottom: 1rem;
  }

  .hero__subtitulo {
    max-width: 560px;
    margin: 1.25rem auto 2rem;
    font-size: 1.15rem;
    color: var(--cor-texto-suave);
  }

  .sobre-resumo {
    text-align: center;
    max-width: 680px;
  }

  .sobre-resumo__link {
    display: inline-block;
    margin-top: 1rem;
    font-weight: 700;
    text-decoration: none;
  }

  .modalidades-grade {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .modalidade-cartao {
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease;
  }

  .modalidade-cartao:hover {
    transform: translateY(-4px);
  }

  .modalidade-cartao__ritmo {
    display: inline-block;
    background: var(--cor-fundo-suave);
    font-size: 0.78rem;
    font-weight: 700;
    padding: 0.15rem 0.7rem;
    border-radius: 999px;
    margin: 0.4rem 0 0.6rem;
  }

  .modalidade-cartao p {
    font-size: 0.95rem;
    color: var(--cor-texto-suave);
  }

  .modalidades-link {
    text-align: center;
    margin-top: 1.75rem;
  }

  .modalidades-link a {
    font-weight: 700;
    text-decoration: none;
  }

  .noticias-grade {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .noticia-cartao {
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease;
  }

  .noticia-cartao:hover {
    transform: translateY(-4px);
  }

  .noticia-cartao__data {
    font-size: 0.85rem;
    color: var(--cor-texto-suave);
  }

  .cta-final {
    text-align: center;
  }

  .cta-final p {
    margin: 0.75rem 0 1.75rem;
    color: var(--cor-texto-suave);
  }
</style>
